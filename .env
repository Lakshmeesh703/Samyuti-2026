# Project runtime environment
# Add your real key below to enable OpenAI provider directly.
OPENAI_API_KEY=

# 1 (default): if OpenAI key missing/fails, auto-fallback to Edge TTS (no error)
# 0: strict mode, fail when OpenAI is unavailable
OPENAI_FALLBACK_TO_EDGE=1

# Optional
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
